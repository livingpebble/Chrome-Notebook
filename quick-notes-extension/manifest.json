{
  "manifest_version": 3,
  "name": "QuickNotes",
  "version": "1.0",
  "description": "快速笔记扩展 - 记录灵感碎片",
  "permissions": [
    "storage",
    "fileSystem"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
